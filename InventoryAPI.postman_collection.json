{
  "info": {
    "name": "Inventory & Order Management API",
    "description": "Run Register Admin → Register User → Create Category → Create Product → Place Order → Confirm/Cancel. Tokens and IDs are auto-saved.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:8080" },
    { "key": "adminToken",  "value": "" },
    { "key": "userToken",   "value": "" },
    { "key": "categoryId",  "value": "" },
    { "key": "productId",   "value": "" },
    { "key": "orderId",     "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) pm.collectionVariables.set('adminToken', pm.response.json().token);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin1\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register?role=ADMIN", "host": ["{{baseUrl}}"], "path": ["api","auth","register"], "query": [{ "key": "role", "value": "ADMIN" }] }
          }
        },
        {
          "name": "Register User",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) pm.collectionVariables.set('userToken', pm.response.json().token);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user1\",\n  \"email\": \"user@example.com\",\n  \"password\": \"user1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register?role=USER", "host": ["{{baseUrl}}"], "path": ["api","auth","register"], "query": [{ "key": "role", "value": "USER" }] }
          }
        },
        {
          "name": "Login Admin",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) pm.collectionVariables.set('adminToken', pm.response.json().token);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin1\",\n  \"password\": \"admin1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Login User",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) pm.collectionVariables.set('userToken', pm.response.json().token);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"user1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        }
      ]
    },
    {
      "name": "Categories [ADMIN]",
      "item": [
        {
          "name": "Create Category",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) pm.collectionVariables.set('categoryId', pm.response.json().id);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic devices and accessories\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api","categories"] }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api","categories"] }
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api","categories","{{categoryId}}"] }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electronics & Gadgets\",\n  \"description\": \"Updated description\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api","categories","{{categoryId}}"] }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api","categories","{{categoryId}}"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product [ADMIN]",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) pm.collectionVariables.set('productId', pm.response.json().id);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Wireless Headphones\",\n  \"description\": \"Noise-cancelling over-ear headphones\",\n  \"price\": 149.99,\n  \"stockQuantity\": 50,\n  \"categoryIds\": [\"{{categoryId}}\"]\n}" },
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] }
          }
        },
        {
          "name": "Get All Products (sorted by price asc)",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/products?page=0&size=10&sortBy=price&direction=asc", "host": ["{{baseUrl}}"], "path": ["api","products"], "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "10" }, { "key": "sortBy", "value": "price" }, { "key": "direction", "value": "asc" }] }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api","products","{{productId}}"] }
          }
        },
        {
          "name": "Search Products by Name",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/products/search?name=wireless&page=0&size=10", "host": ["{{baseUrl}}"], "path": ["api","products","search"], "query": [{ "key": "name", "value": "wireless" }, { "key": "page", "value": "0" }, { "key": "size", "value": "10" }] }
          }
        },
        {
          "name": "Filter by Category",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/products/category/{{categoryId}}?sortBy=price&direction=asc", "host": ["{{baseUrl}}"], "path": ["api","products","category","{{categoryId}}"], "query": [{ "key": "sortBy", "value": "price" }, { "key": "direction", "value": "asc" }] }
          }
        },
        {
          "name": "Low-Stock Products",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/products/low-stock?threshold=10", "host": ["{{baseUrl}}"], "path": ["api","products","low-stock"], "query": [{ "key": "threshold", "value": "10" }] }
          }
        },
        {
          "name": "Update Product [ADMIN]",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Wireless Headphones Pro\",\n  \"price\": 179.99,\n  \"stockQuantity\": 75,\n  \"active\": true\n}" },
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api","products","{{productId}}"] }
          }
        },
        {
          "name": "Delete Product [ADMIN]",
          "request": {
            "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api","products","{{productId}}"] }
          }
        }
      ]
    },
    {
      "name": "Orders [USER]",
      "item": [
        {
          "name": "Place Order",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) pm.collectionVariables.set('orderId', pm.response.json().id);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 3 }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api","orders"] }
          }
        },
        {
          "name": "Get Order History",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders?page=0&size=10", "host": ["{{baseUrl}}"], "path": ["api","orders"], "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "10" }] }
          }
        },
        {
          "name": "Filter Orders by Status (CREATED)",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders?status=CREATED", "host": ["{{baseUrl}}"], "path": ["api","orders"], "query": [{ "key": "status", "value": "CREATED" }] }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api","orders","{{orderId}}"] }
          }
        },
        {
          "name": "Confirm Order",
          "request": {
            "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/confirm", "host": ["{{baseUrl}}"], "path": ["api","orders","{{orderId}}","confirm"] }
          }
        },
        {
          "name": "Cancel Order (restores stock)",
          "request": {
            "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api","orders","{{orderId}}","cancel"] }
          }
        }
      ]
    }
  ]
}
